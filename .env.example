# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# For db:migrate - get from Dashboard > Database > Connection string (URI)
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Custom Backend
PORT=3001
API_BASE_URL=http://localhost:3001

# Google Maps
GOOGLE_MAPS_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# MailerSend
MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=noreply@rentalcity.com

# Custom SMTP (optional – used by backend or Supabase custom SMTP)
# Copy your real values from DishReview or your provider; do not commit secrets.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_SECURE=false
SMTP_IGNORE_TLS=false

# Plaid (optional)
PLAID_CLIENT_ID=
PLAID_SECRET=

# SmartMove (TBD)
SMARTMOVE_API_KEY=
